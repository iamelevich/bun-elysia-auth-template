{
  "name": "@app/server",
  "private": true,
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir ../dist --target bun --sourcemap",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:drop": "drizzle-kit drop",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run scripts/seed.ts",
    "db:logs:pull": "drizzle-kit pull --config log.drizzle.config.ts",
    "db:logs:push": "drizzle-kit push --config log.drizzle.config.ts",
    "db:logs:check": "drizzle-kit check --config log.drizzle.config.ts",
    "db:logs:generate": "drizzle-kit generate --config log.drizzle.config.ts",
    "db:logs:drop": "drizzle-kit drop --config log.drizzle.config.ts",
    "db:logs:studio": "drizzle-kit studio --config log.drizzle.config.ts",
    "db:logs:seed": "bun run scripts/seed.ts --config log.drizzle.config.ts",
    "format": "biome format",
    "format:write": "biome format --write",
    "lint": "biome lint",
    "lint:write": "biome lint --write",
    "check": "biome check"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/bun": "1.3.13",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/static": "^1.4.10",
    "@sinclair/typebox": "^0.34.49",
    "@tqman/nice-logger": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.28",
    "picocolors": "^1.1.1"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ],
  "exports": {
    ".": "./src/exports.ts"
  }
}
